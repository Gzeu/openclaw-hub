{"version": 2, "buildCommand": "npm run build", "outputDirectory": ".next", "installCommand": "npm install", "framework": "nextjs", "routes": [{"src": "/api/(.*)", "dest": "/api/$1"}], "functions": {"api/*.ts": {"maxDuration": 30}, "app/api/cron/agent-loop.ts": {"maxDuration": 60}, "app/api/acp/route.ts": {"maxDuration": 30}, "app/api/acp/broadcast/route.ts": {"maxDuration": 30}, "app/api/mcp/route.ts": {"maxDuration": 30}}, "headers": [{"source": "/api/:path*", "headers": [{"key": "Access-Control-Allow-Origin", "value": "*"}, {"key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS"}, {"key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, x-api-key, x-cron-secret, x-mcp-api-key"}]}, {"source": "/.well-known/:path*", "headers": [{"key": "Access-Control-Allow-Origin", "value": "*"}, {"key": "Cache-Control", "value": "public, max-age=3600"}]}], "crons": [{"path": "/api/cron/agent-loop", "schedule": "0 0 * * *"}]}
