// OPENCLAW HUB — Agent Health Monitoring System
// Automated agent status checking with real-time monitoring
// ═══════════════════════════════════════════════════════════════════════════

import { NextRequest, NextResponse } from 'next/server'
import type { AgentProfile } from '@/lib/agent-profiles'

export const runtime = 'edge'

interface HealthCheckResult {
  agent_id: string
  status: 'healthy' | 'degraded' | 'unhealthy'
  score: number
  checks: HealthCheck[]
  timestamp: string
  duration: number
}

interface HealthCheck {
  name: string
  status: 'pass' | 'fail' | 'warn'
  message: string
  response_time?: number
  details?: any
}

interface AgentEndpoint {
  name: string
  url: string
  protocol: string
  version?: string
  status: 'active' | 'inactive' | 'error'
  last_checked?: string
  response_time?: number
}

// Health check configurations for different protocols
const HEALTH_CHECK_CONFIGS = {
  'MCP': {
    timeout: 5000,
    expectedStatus: 200,
    checks: ['connectivity', 'version', 'tools', 'resources']
  },
  'A2A': {
    timeout: 5000,
    expectedStatus: 200,
    checks: ['connectivity', 'version', 'skills']
  },
  'OASF': {
    timeout: 5000,
    expectedStatus: 200,
    checks: ['connectivity', 'version', 'skills', 'domains']
  },
  'Web': {
    timeout: 10000,
    expectedStatus: 200,
    checks: ['connectivity', 'content']
  },
  'API': {
    timeout: 5000,
    expectedStatus: 200,
    checks: ['connectivity', 'api_version']
  }
}

// Perform HTTP health check
async function performHTTPHealthCheck(url: string, config: any): Promise<HealthCheck> {
  const startTime = Date.now()
  
  try {
    const controller = new AbortController()
    const timeoutId = setTimeout(() => controller.abort(), config.timeout)
    
    const response = await fetch(url, {
      method: 'GET',
      signal: controller.signal,
      headers: {
        'User-Agent': 'OpenClaw-Hub-Health-Checker/1.0'
      }
    })
    
    clearTimeout(timeoutId)
    const responseTime = Date.now() - startTime
    
    if (response.status === config.expectedStatus) {
      return {
        name: 'connectivity',
        status: 'pass',
        message: `Endpoint is accessible (${response.status})`,
        response_time
      }
    } else {
      return {
        name: 'connectivity',
        status: 'fail',
        message: `Unexpected status: ${response.status}`,
        response_time
      }
    }
  } catch (error) {
    const responseTime = Date.now() - startTime
    return {
      name: 'connectivity',
      status: 'fail',
      message: `Connection failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
      response_time
    }
  }
}

// Perform MCP-specific health check
async function performMCPHealthCheck(endpoint: string): Promise<HealthCheck[]> {
  const checks: HealthCheck[] = []
  
  try {
    // Check basic connectivity
    const connectivityCheck = await performHTTPHealthCheck(endpoint, HEALTH_CHECK_CONFIGS.MCP)
    checks.push(connectivityCheck)
    
    // Check MCP version
    try {
      const versionResponse = await fetch(`${endpoint}/version`, {
        method: 'GET',
        signal: AbortSignal.timeout(5000)
      })
      
      if (versionResponse.ok) {
        const version = await versionResponse.text()
        checks.push({
          name: 'version',
          status: 'pass',
          message: `MCP version: ${version.trim()}`
        })
      } else {
        checks.push({
          name: 'version',
          status: 'warn',
          message: 'Could not fetch MCP version'
        })
      }
    } catch (error) {
      checks.push({
        name: 'version',
        status: 'fail',
        message: `Version check failed: ${error instanceof Error ? error.message : 'Unknown error'}`
      })
    }
    
    // Check tools availability
    try {
      const toolsResponse = await fetch(`${endpoint}/tools/list`, {
        method: 'GET',
        signal: AbortSignal.timeout(5000)
      })
      
      if (toolsResponse.ok) {
        const tools = await toolsResponse.json()
        checks.push({
          name: 'tools',
          status: 'pass',
          message: `Available tools: ${tools.length}`,
          details: { tools }
        })
      } else {
        checks.push({
          name: 'tools',
          status: 'warn',
          message: 'Could not fetch tools list'
        })
      }
    } catch (error) {
      checks.push({
        name: 'tools',
        status: 'fail',
        message: `Tools check failed: ${error instanceof Error ? error.message : 'Unknown error'}`
      })
    }
    
    // Check resources availability
    try {
      const resourcesResponse = await fetch(`${endpoint}/resources/list`, {
        method: 'GET',
        signal: AbortSignal.timeout(5000)
      })
      
      if (resourcesResponse.ok) {
        const resources = await resourcesResponse.json()
        checks.push({
          name: 'resources',
          status: 'pass',
          message: `Available resources: ${resources.length}`,
          details: { resources }
        })
      } else {
        checks.push({
          name: 'resources',
          status: 'warn',
          message: 'Could not fetch resources list'
        })
      }
    } catch (error) {
      checks.push({
        name: 'resources',
        status: 'fail',
        message: `Resources check failed: ${error instanceof Error ? error.message : 'Unknown error'}`
      })
    }
    
  } catch (error) {
    checks.push({
      name: 'mcp_general',
      status: 'fail',
      message: `MCP health check failed: ${error instanceof Error ? error.message : 'Unknown error'}`
    })
  }
  
  return checks
}

// Perform A2A-specific health check
