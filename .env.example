# ─── Database ──────────────────────────────────────────────────────────────
# MongoDB Atlas free tier: https://cloud.mongodb.com (M0 — 512MB, always free)
# Local dev: mongodb://localhost:27017/openclaw
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/openclaw?retryWrites=true&w=majority

# Encryption key for API keys stored in DB (use a 32-char random string)
ENCRYPTION_KEY=your-32-character-random-secret!!

# ─── Authentication ─────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Internal API protection (generate: openssl rand -hex 32)
AGENTS_API_KEY=

# ─── WorkOS AuthKit Configuration (Required for authentication)
NEXT_PUBLIC_WORKOS_CLIENT_ID=your-workos-client-id
WORKOS_CLIENT_ID=your-workos-client-id
WORKOS_API_KEY=sk_test_your-workos-api-key
WORKOS_SECRET_KEY=sk_test_your-workos-secret-key
WORKOS_COOKIE_PASSWORD=your-base32-cookie-password-min-32-chars
WORKOS_REDIRECT_URI=https://your-app.vercel.app/auth/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=https://your-app.vercel.app/auth/callback
NEXT_PUBLIC_WORKOS_URL=https://api.workos.com
WORKOS_URL=https://api.workos.com

# WorkOS Publishable Key (Get from WorkOS Dashboard -> API Keys)
NEXT_PUBLIC_WORKOS_PUBLISHABLE_KEY=pk_test_your-publishable-key

# ─── Convex Configuration ─────────────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=https://chatty-eagle-75.eu-west-1.convex.cloud
